    "line_patterns": {
      "allowed_item_prefixes": [],
      "allowed_items": [
        "line_pattern.segment_count",
        "line_pattern.segments_def_hash"
      ],
      "hash_alg": "md5_utf8_join_pipe",
      "minima": {
        "block_if_any_required_not_ok": true
      },
      "notes": [
        "sig_hash uses segment_count + segments_def_hash: matches extractor preimage exactly.",
        "segments_norm_hash excluded from sig_hash — belongs in join_hash only (policy v3).",
        "sig_hash distinguishes scale variants; join_hash collapses them for governance equivalence.",
        "Cross-domain refs (obj_style.pattern_ref.sig_hash, line_style.pattern_ref.sig_hash) are written",
        "at extraction time from ctx[line_pattern_uid_to_hash] which holds the extractor-computed sig_hash.",
        "Post-extraction sig_hash recomputation must produce the same value for ctx refs to remain valid.",
        "Indexed seg[NNN].* items are in identity_basis.items (canonical evidence) but NOT in the preimage;",
        "allowed_item_prefixes is [] so the policy stage hashes only segment_count + segments_def_hash.",
        "sig_hash is computed post-extraction from canonical identity_basis.items."
      ],
      "required_items": [
        "line_pattern.segment_count",
        "line_pattern.segments_def_hash"
      ],
