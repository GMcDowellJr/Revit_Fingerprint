{
  "domains": {
    "identity": {
      "join_key_schema": "identity.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "identity.is_workshared"
      ],
      "optional_items": [
        "identity.revit_version_number",
        "identity.revit_build",
        "identity.revit_version_name"
      ],
      "explicitly_excluded_items": [
        "identity.central_path",
        "identity.central_path_norm",
        "identity.filename",
        "identity.project_title"
      ],
      "shape_gating": {
        "discriminator_key": "identity.is_workshared",
        "shape_requirements": {
          "true": {
            "additional_required": [
              "identity.revit_version_number"
            ],
            "additional_optional": [],
            "notes": "Workshared identity joins include version number as discriminator-gated required context."
          }
        },
        "default_shape_behavior": "common_only"
      },
      "notes": [
        "Pilot for canonical evidence superset + selectors in the identity domain.",
        "join_hash uses policy-required items only; optional items remain in identity_basis.items for future exploration.",
        "File-local identifiers remain excluded from canonical identity evidence and join-key hashing."
      ]
    },
    "phase_filters": {
      "join_key_schema": "phase_filters.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "phase_filter.name"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [],
      "notes": [
        "Pareto evidence showed zero fragmentation and zero collisions with name-only in the evaluated population.",
        "This is a label-based join pending availability/export of definition-bearing identity fields for phase filters; treat as provisional."
      ]
    },
    "phases": {
      "join_key_schema": "phases.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "phase.name"
      ],
      "optional_items": [
        "phase.seq"
      ],
      "explicitly_excluded_items": [],
      "notes": [
        "Policy is provisional pending broader samples; current Pareto evidence shows zero fragmentation and zero collisions for both phase.name and phase.seq.",
        "phase.name is treated as the definition-bearing identifier in current evidence; phase.seq may be added only if future datasets exhibit name collisions."
      ]
    },
    "units": {
      "join_key_schema": "units.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "units.spec",
        "units.unit_type_id",
        "units.rounding_method"
      ],
      "optional_items": [
        "units.accuracy"
      ],
      "explicitly_excluded_items": [],
      "notes": [
        "Accuracy moved to optional - display precision preference, not behavioral identity.",
        "Spec + type + rounding define the unit system (feet-inches, metric, etc.).",
        "Accuracy variance (0.01 vs 1.0) is display formatting, not calculation behavior.",
        "DECISION: Accuracy affects display only, not technical behavior - treat as refinement."
      ]
    },
    "line_patterns": {
      "join_key_schema": "line_patterns.join_key.v2",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "line_pattern.segments_def_hash"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "line_pattern.uid",
        "line_pattern.name",
        "line_pattern.element_id",
        "line_pattern.uid_or_namekey"
      ],
      "notes": [
        "Identity is definition-based via ordered segment (kind,length) sequence; segments are collapsed into line_pattern.segments_def_hash.",
        "line_pattern.segments_def_hash must be derived only from segment kinds and lengths in order and must not incorporate UID, name, or element_id.",
        "Names are labels only and must not participate in joins.",
        "lp.is_import added to coordination_items in extractor v2."
      ]
    },
    "line_styles": {
      "join_key_schema": "line_styles.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "line_style.weight.projection",
        "line_style.color.rgb",
        "line_style.pattern_ref.sig_hash"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "line_style.path",
        "line_style.pattern_ref.kind"
      ],
      "notes": [
        "Identity is definition-based: projection weight + color + referenced line pattern definition via pattern_ref.sig_hash.",
        "pattern_ref.kind is too coarse and produces high collisions; it must not be used for joins."
      ]
    },
    "arrowheads": {
      "join_key_schema": "arrowheads.join_key.v2",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "arrowhead.style",
        "arrowhead.tick_size_in"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "arrowhead.name",
        "arrowhead.type_id",
        "arrowhead.width_angle_deg",
        "arrowhead.fill_tick",
        "arrowhead.arrow_closed",
        "arrowhead.tick_mark_centered",
        "arrowhead.heavy_end_pen_weight"
      ],
      "shape_gating": {
        "discriminator_key": "arrowhead.style",
        "shape_requirements": {
          "Arrow": {
            "additional_required": [
              "arrowhead.width_angle_deg",
              "arrowhead.fill_tick",
              "arrowhead.arrow_closed"
            ],
            "additional_optional": [],
            "notes": "Arrow record class: arrow-specific geometry + fill/closed flags are applicable and required."
          },
          "Heavy end tick mark": {
            "additional_required": [
              "arrowhead.tick_mark_centered",
              "arrowhead.heavy_end_pen_weight"
            ],
            "additional_optional": [],
            "notes": "Heavy end tick mark record class: centered and pen weight are applicable and required."
          }
        },
        "default_shape_behavior": "common_only"
      },
      "notes": [
        "Schema v2: record class routing corrected. Dot/Diagonal/Box/Loop/Elevation Target/Datum triangle are size-only (common items only).",
        "Arrow record class: arrowhead.width_angle_deg, arrowhead.fill_tick, arrowhead.arrow_closed.",
        "Heavy end tick mark record class: arrowhead.tick_mark_centered, arrowhead.heavy_end_pen_weight.",
        "Size-only record classes (Dot/Diagonal/Box/Loop/Elevation Target/Datum triangle): common items only (arrowhead.style + arrowhead.tick_size_in).",
        "Style-specific fields moved from optional_items to explicitly_excluded_items at common level — they are never unconditionally applicable.",
        "Definition-based identity only; no referential identifiers in joins."
      ]
    },
    "text_types": {
      "join_key_schema": "text_types.join_key.v2",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "text_type.font",
        "text_type.size_in",
        "text_type.bold",
        "text_type.italic",
        "text_type.underline",
        "text_type.color_rgb",
        "text_type.width_factor"
      ],
      "optional_items": [
        "text_type.leader_arrowhead_sig_hash",
        "text_type.background_raw",
        "text_type.line_weight",
        "text_type.show_border",
        "text_type.tab_size_in",
        "text_type.leader_border_offset_in"
      ],
      "explicitly_excluded_items": [
        "text_type.name",
        "text_type.type_id",
        "text_type.type_uid",
        "text_type.leader_arrowhead_uid",
        "text_type.leader_arrowhead_name",
        "text_type.color_int"
      ],
      "notes": [
        "Policy: color_rgb is definition-bearing.",
        "Policy: arrowhead is definition-bearing only via arrowheads-domain signature hash (text_type.leader_arrowhead_sig_hash), not uid/name/id.",
        "If text_type.leader_arrowhead_sig_hash is unavailable for some records, treat as lower confidence rather than substituting uid/name."
      ]
    },
    "view_filter_definitions": {
      "join_key_schema": "view_filter_definitions.join_key.v2",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "vf.def_hash"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "vf.uid_or_namekey",
        "vf.elem_id",
        "vf.categories",
        "vf.logic_root",
        "vf.rule_count",
        "vf.rules[].sig",
        "label.components.name",
        "label.display"
      ],
      "notes": [
        "Structured domain: join is performed on vf.def_hash only (definition bundle hash).",
        "vf.def_hash is computed from canonical vf.categories + vf.logic_root + vf.rule_count + ordered vf.rule[###].sig, but those leaf inputs remain identity-only for forensics.",
        "Names/labels and any UID-like identifiers are prohibited from joins for standards governance."
      ]
    },
    "view_filter_applications_view_templates": {
      "join_key_schema": "view_filter_applications_view_templates.join_key.v2",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "vfa.stack_def_hash"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "vfa.template_uid_or_namekey",
        "vfa.template_elem_id",
        "vfa.filter_stack_count",
        "vfa.stack[].filter_sig_hash",
        "vfa.stack[].visible",
        "vfa.stack[].enabled"
      ],
      "notes": [
        "Structured-sequence domain: join identity is the ordered filter-stack definition collapsed into vfa.stack_def_hash.",
        "Leaf stack members and counts are authoritative identity (identity_basis) but must not participate in joins.",
        "Template identifiers are labels/linkage only and are prohibited from joins."
      ]
    },
    "view_category_overrides": {
      "join_key_schema": "view_category_overrides.join_key.v1",
      "hash_alg": "md5_utf8_join_pipe",
      "required_items": [
        "vco.baseline_category_path",
        "vco.baseline_sig_hash",
        "vco.override_properties_hash"
      ],
      "optional_items": [],
      "explicitly_excluded_items": [
        "vco.category_path",
        "vco.projection.line_weight",
        "vco.projection.line_pattern_ref.sig_hash",
        "vco.projection.line_color.rgb",
        "vco.cut.line_weight",
        "vco.cut.line_pattern_ref.sig_hash",
        "vco.cut.line_color.rgb",
        "vco.halftone",
        "vco.transparency"
      ],
      "notes": [
        "Join-key identity captures the override pattern, not where it's used.",
        "vco.baseline_category_path identifies WHICH category is being overridden.",
        "vco.baseline_sig_hash identifies the object_styles baseline definition being overridden.",
        "vco.override_properties_hash collapses all delta properties into a single behavioral signature.",
        "Individual delta properties (line_weight, color, etc.) are forensic detail, excluded from joins."
      ]
    },
